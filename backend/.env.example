# System MAC · ejemplo de configuración local
# Configurable desde Admin → IA.
OPERATIVA_AI_MODE=openai
OPENAI_API_KEY=sk-pon_tu_clave_aqui
OPERATIVA_AI_MODEL=gpt-4o-mini

# Voz: recomendado Deepgram para transcripción; OpenAI queda como comprensión/fallback.
STT_PROVIDER=deepgram
OPERATIVA_STT_MODE=deepgram
DEEPGRAM_API_KEY=pon_tu_clave_deepgram_aqui
DEEPGRAM_MODEL=nova-3
STT_LANGUAGE=es
OPENAI_STT_MODEL=gpt-4o-mini-transcribe

OPERATIVA_LANGUAGE=es
OIDO_ALFI_LANGUAGE=es
RECIPE_VOICE_LANGUAGE=es
OPERATIVA_AI_TIMEOUT=12
OPERATIVA_STT_TIMEOUT=25
RECIPE_AI_PROVIDER=auto
